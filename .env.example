# ============================================================
# BeatPost — Variaveis de Ambiente
# ============================================================
# Copie pra .env (api/) e .env.local (web/) e preencha.
# NUNCA commitar arquivos .env reais.

# -------------------------------------------
# Ambiente
# -------------------------------------------
ENVIRONMENT=development
DEBUG=true

# -------------------------------------------
# Supabase (compartilhado entre web/ e api/)
# -------------------------------------------
# Web (.env.local) usa NEXT_PUBLIC_*
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_ID].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# API (.env) usa service role
SUPABASE_URL=https://[PROJECT_ID].supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_VAULT_KEY=                  # chave simetrica pra pgp_sym_encrypt do refresh_token

# -------------------------------------------
# IA Providers
# -------------------------------------------
GOOGLE_API_KEY=                      # Gemini 2.0 Flash (audio + grounded search)
ANTHROPIC_API_KEY=                   # Claude Sonnet 4.6 (geracao A/B/C)

# -------------------------------------------
# YouTube Data API v3 (OAuth 2.0)
# -------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://[DOMAIN]/api/youtube/callback

# -------------------------------------------
# Upstash QStash (worker async)
# -------------------------------------------
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# -------------------------------------------
# API publica (web → api)
# -------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
API_HOST=0.0.0.0
API_PORT=8000

# -------------------------------------------
# CORS
# -------------------------------------------
CORS_ORIGINS=http://localhost:3000
